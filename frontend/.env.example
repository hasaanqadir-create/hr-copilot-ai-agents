# The frontend talks to the backend via Vite's dev proxy (see vite.config.ts),
# which forwards /api and /uploads to http://localhost:5000. No env vars are
# required for local development. If you deploy frontend and backend to
# different domains, set VITE_API_URL and update src/lib/api.ts to use it.
VITE_API_URL=http://localhost:5000
