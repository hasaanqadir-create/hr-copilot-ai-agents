# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/hr-copilot

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# AI Provider (choose ONE — code is provider-agnostic)
# Set AI_PROVIDER to: openai | gemini | anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# File storage
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Future integrations (Phase 4/5)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
RESEND_API_KEY=
